APP_NAME="PSMMS Dashboard"
APP_URL=http://localhost:8000
APP_DEBUG=true
APP_ENV=development

DB_HOST=localhost
DB_NAME=psmms_db
DB_USER=root
DB_PASS=
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_password
MAIL_FROM=your@email.com
MAIL_FROM_NAME="PSMMS Dashboard"

JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

SESSION_NAME=PSMMS_SESSION
SESSION_LIFETIME=7200

CACHE_DRIVER=file
CACHE_TTL=3600

APP_LOCALE=en
APP_TIMEZONE=UTC
