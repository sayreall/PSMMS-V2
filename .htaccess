Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(app|database|node_modules|routes|vendor)(/|$) - [F,L]
    RewriteRule ^(\.git|\.vscode)(/|$) - [F,L]

    RewriteRule ^$ public/ [L]

    RewriteCond %{REQUEST_URI} !/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)$ public/$1 [L]
</IfModule>

<FilesMatch "^(\.env(\..*)?|composer\.(json|lock)|package(-lock)?\.json|psmms_db\.sql|settings\.json|cspell\.json|.*\.log)$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log|env|ini|bak|config)$">
    Require all denied
</FilesMatch>
